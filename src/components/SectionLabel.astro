---
interface Props {
  number: string;
  label: string;
}
const { number, label } = Astro.props;
---
<p class="section-label">
  <span class="section-num">§{number}</span>
  <span class="section-rule" aria-hidden="true"></span>
  <span class="section-text">{label}</span>
</p>

<style>
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    font-weight: 600;
    margin-bottom: var(--space-4);
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, monospace;
  }

  .section-num {
    font-weight: 500;
  }

  .section-rule {
    display: inline-block;
    width: 36px;
    height: 1px;
    background: currentColor;
    opacity: 0.45;
  }

  .section-text {
    font-weight: 600;
  }
</style>
