---
import Icons from './Icons.astro';

const path = Astro.url.pathname;
const isActive = (p: string) => (p === '/' ? path === '/' : path.startsWith(p));

const items = [
  { href: '/', label: '首頁' },
  { href: '/about', label: '關於我' },
  { href: '/privacy', label: '隱私政策' },
];
---
<header class="site-nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label="廖偉翔首頁">
      <span class="brand-mark" aria-hidden="true">SL</span>
      <span class="brand-name">廖偉翔</span>
    </a>

    <nav class="nav-desktop" aria-label="主要導航">
      {items.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', isActive(item.href) && 'is-active']}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button
      class="nav-toggle"
      type="button"
      aria-label="開啟選單"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <span class="icon-menu"><Icons name="menu" /></span>
      <span class="icon-close"><Icons name="x" /></span>
    </button>
  </div>

  <nav id="nav-mobile" class="nav-mobile" aria-label="行動裝置主要導航" hidden>
    {items.map((item) => (
      <a
        href={item.href}
        class:list={['mobile-link', isActive(item.href) && 'is-active']}
        aria-current={isActive(item.href) ? 'page' : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 86%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .brand:hover {
    color: var(--color-accent-dark);
    text-decoration: none;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--color-primary);
    color: var(--color-bg);
    border-radius: 8px;
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, monospace;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    font-weight: 700;
  }

  .nav-desktop {
    display: none;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    position: relative;
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 500;
    padding: var(--space-1) 0;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-accent-dark);
    text-decoration: none;
  }

  .nav-link.is-active {
    color: var(--color-primary);
  }

  .nav-link.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }

  .nav-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  .nav-toggle:hover {
    border-color: var(--color-text);
  }

  @media (min-width: 768px) {
    .nav-toggle {
      display: none;
    }
  }

  .nav-toggle .icon-close {
    display: none;
  }

  .nav-toggle[aria-expanded='true'] .icon-menu {
    display: none;
  }

  .nav-toggle[aria-expanded='true'] .icon-close {
    display: inline-flex;
  }

  .nav-mobile {
    display: flex;
    flex-direction: column;
    padding: var(--space-3) 0;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .nav-mobile[hidden] {
    display: none;
  }

  .mobile-link {
    padding: var(--space-3) var(--space-4);
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-link:last-child {
    border-bottom: none;
  }

  .mobile-link.is-active {
    color: var(--color-accent-dark);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const mobile = document.getElementById('nav-mobile');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    if (mobile) {
      if (isOpen) {
        mobile.setAttribute('hidden', '');
      } else {
        mobile.removeAttribute('hidden');
      }
    }
  });

  // Close mobile menu when link clicked
  mobile?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      mobile.setAttribute('hidden', '');
    });
  });
</script>
