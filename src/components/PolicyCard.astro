---
interface Props {
  number: string;
  title: string;
  description: string;
  href?: string;
}
const { number, title, description, href = '#' } = Astro.props;
---
<article class="policy-card">
  <a href={href} class="card-link" aria-label={`${title}：了解更多`}>
    <span class="card-number">{number}</span>
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
    <span class="card-cta">
      <span>了解更多</span>
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
      </svg>
    </span>
  </a>
</article>

<style>
  .policy-card {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .policy-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 36px;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .policy-card:hover,
  .policy-card:focus-within {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .policy-card:hover::before,
  .policy-card:focus-within::before {
    width: 100%;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-4) var(--space-4);
    color: inherit;
    text-decoration: none;
    height: 100%;
  }

  .card-link:hover {
    text-decoration: none;
  }

  .card-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -4px;
    border-radius: var(--radius);
  }

  .card-number {
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, monospace;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-accent-dark);
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.02em;
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.95rem;
    color: var(--color-text-mute);
    line-height: 1.65;
    margin-bottom: var(--space-2);
    flex: 1;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    letter-spacing: 0.02em;
    transition: gap 0.25s ease, color 0.25s ease;
  }

  .policy-card:hover .card-cta,
  .policy-card:focus-within .card-cta {
    gap: var(--space-2);
    color: var(--color-accent-dark);
  }
</style>
