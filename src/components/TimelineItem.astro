---
interface Props {
  step: string;
  year: string;
  role: string;
  org: string;
  description: string;
  isLast?: boolean;
}
const { step, year, role, org, description, isLast = false } = Astro.props;
---
<article class={`timeline-item${isLast ? ' is-last' : ''}`}>
  <div class="mark">
    <span class="step">{step}</span>
    <span class="dot" aria-hidden="true"></span>
  </div>
  <div class="body">
    <p class="year">{year}</p>
    <h3 class="role">{role}</h3>
    <p class="org">{org}</p>
    <p class="description">{description}</p>
  </div>
</article>

<style>
  .timeline-item {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: var(--space-4);
    position: relative;
    padding-bottom: var(--space-6);
  }

  .timeline-item:not(.is-last) .mark::after {
    content: '';
    position: absolute;
    top: 30px;
    bottom: -16px;
    left: calc(50% - 0.5px);
    width: 1px;
    background: var(--color-border);
  }

  .mark {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 4px;
  }

  .step {
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--color-accent-dark);
    margin-bottom: var(--space-2);
  }

  .dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 2px solid var(--color-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .body {
    padding-top: 4px;
  }

  .year {
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, monospace;
    font-size: 0.85rem;
    color: var(--color-text-mute);
    margin-bottom: var(--space-1);
    letter-spacing: 0.05em;
  }

  .role {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 2px;
    letter-spacing: 0.01em;
    line-height: 1.3;
  }

  .org {
    font-size: 0.95rem;
    color: var(--color-accent-dark);
    margin-bottom: var(--space-2);
    font-weight: 500;
  }

  .description {
    font-size: 0.95rem;
    color: var(--color-text-mute);
    line-height: 1.7;
    max-width: 38em;
  }
</style>
